{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Represents a product in the store",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the product" },
        "price": { "type": "number", "description": "The price of the product" },
        "image": { "type": "string", "description": "URL to the product image" }
      },
      "required": ["name", "price", "image"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products"
    }
  }
}
